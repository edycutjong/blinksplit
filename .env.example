# frontier-100xdevs Environment Variables
# Copy to .env.local and fill in values

# Solana RPC
# Get a custom RPC at: https://helius.dev or use the default public devnet RPC
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Solana fee/receiver account
# Provide your Solana wallet address (e.g., from Phantom or Solflare)
NEXT_PUBLIC_FEE_ACCOUNT=

# OpenAI (for receipt parsing — falls back to demo data if missing)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Solana Blinks (optional)
# Get your API key or configure settings via Dialect: https://dialect.to
NEXT_PUBLIC_BLINKS_API_KEY=

# Supabase (for database/storage)
# Get your Project URL and Anon Key at: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
